RewriteEngine On
RewriteBase /

# Never cache HTML - prevents post-deploy blank screens from stale index.html
# pointing at old hashed JS chunks.
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Hashed JS/CSS can be cached forever
  <FilesMatch "\.(js|css|mjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Long-cache static portfolio screenshots and fonts
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|woff2|woff|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# SPA fallback: serve index.html for client routes (refresh / deep links)
Options -MultiViews
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
